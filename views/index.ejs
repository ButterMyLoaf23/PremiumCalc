<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PremiumCalc Pro</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>

<div class="calculator">

    <div id="display" class="display">0</div>

    <form id="calcForm" action="/calculate" method="POST">

        <input type="hidden" name="num1" id="num1">
        <input type="hidden" name="num2" id="num2">
        <input type="hidden" name="operation" id="operation">

        <div class="buttons">

            <button type="button" onclick="appendNumber('7')">7</button>
            <button type="button" onclick="appendNumber('8')">8</button>
            <button type="button" onclick="appendNumber('9')">9</button>
            <button type="button" onclick="setOperation('/')">÷</button>

            <button type="button" onclick="appendNumber('4')">4</button>
            <button type="button" onclick="appendNumber('5')">5</button>
            <button type="button" onclick="appendNumber('6')">6</button>
            <button type="button" onclick="setOperation('*')">×</button>

            <button type="button" onclick="appendNumber('1')">1</button>
            <button type="button" onclick="appendNumber('2')">2</button>
            <button type="button" onclick="appendNumber('3')">3</button>
            <button type="button" onclick="setOperation('-')">−</button>

            <button type="button" onclick="clearCalc()">C</button>
            <button type="button" onclick="appendNumber('0')">0</button>
            <button type="button" onclick="appendDecimal()">.</button>
            <button type="button" onclick="setOperation('+')">+</button>

            <button
                type="button"
                class="equals"
                onclick="submitCalculation()"
            >
                =
            </button>

        </div>

    </form>

</div>

<script>

let firstNumber = "";
let secondNumber = "";
let operator = "";

function updateDisplay(){

    document.getElementById("display").textContent =
        firstNumber + operator + secondNumber || "0";
}

function appendNumber(num){

    if(operator === ""){
        firstNumber += num;
    }
    else{
        secondNumber += num;
    }

    updateDisplay();
}

function appendDecimal(){

    if(operator === ""){

        if(!firstNumber.includes(".")){
            firstNumber += ".";
        }

    } else {

        if(!secondNumber.includes(".")){
            secondNumber += ".";
        }
    }

    updateDisplay();
}

function setOperation(op){

    if(firstNumber === "") return;

    operator = op;

    updateDisplay();
}

function clearCalc(){

    firstNumber = "";
    secondNumber = "";
    operator = "";

    updateDisplay();
}

function submitCalculation(){

    if(
        firstNumber === "" ||
        secondNumber === "" ||
        operator === ""
    ){
        alert("Please complete the calculation.");
        return;
    }

    document.getElementById("num1").value =
        firstNumber;

    document.getElementById("num2").value =
        secondNumber;

    document.getElementById("operation").value =
        operator;

    document.getElementById("calcForm").submit();
}

</script>

<% if(error) { %>
    <p class="error"><%= error %></p>
<% } %>

<% if(result !== null) { %>

<div id="paywall">

    <div class="paywall-card">

        <h1>🔒 Result Locked</h1>

        <div class="locked-answer">
            ********
        </div>

        <h2><%= tier.name %></h2>

        <h3><%= tier.price %></h3>

        <p>
            Your answer has been successfully calculated.
        </p>

        <p>
            Upgrade to reveal it.
        </p>

        <button 
            type="button"
            onclick="window.location.href='/upgrade'">Upgrade Now</button>

        <button 
            type="button"
            onclick="closePaywall()">
            Maybe Later
        </button>

    </div>

</div>

<% } %>

<script>

function closePaywall() {
    document.getElementById("paywall").style.display = "none";
}

window.onload = () => {
    const paywall = document.getElementById("paywall");

    if(paywall) {
        paywall.style.display = "flex";
    }
}

</script>

</body>
</html>